# Don't put real secrets in this file — it's committed to git as a template.
# Copy to .env and fill in real values on each machine/deployment; .env is gitignored.

NODE_ENV=development
PORT=3000

# Sign/verify JWTs — use a long random string (32+ chars), rotate on production
JWT_SECRET=your-secret-key-here-change-on-deployment-min-32-chars

DB_HOST=localhost
DB_USER=coop_user
DB_PASSWORD=your-db-password-here
DB_NAME=pos_coop
DB_PORT=3306

FRONTEND_URL=http://localhost:5173

# ⭐️ Cloudinary — เก็บรูปอัปโหลด (สลิป/รูปเข้างาน) ถาวรบนคลาวด์
# จำเป็นบน Render/host ที่ดิสก์ ephemeral (ไฟล์หายตอน redeploy). สมัครฟรีที่ cloudinary.com
# ถ้าเว้นว่างทั้ง 3 ค่า ระบบจะ fallback เก็บลงดิสก์ uploads/ (ok เฉพาะ dev เครื่อง local)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Guards the bootstrap endpoints (/api/init-db, /api/seed-data, /api/create-admin, /api/clear-data)
# Leave unset in production to disable these endpoints entirely (server returns 503)
SETUP_KEY=dev-setup-key-change-on-production

# Used by the daily backup job (runBackup() in server.js / backup-mysql.sh) — mysqldump
# runs via `docker exec` against the MySQL container from docker-compose.yml
DB_CONTAINER=pos_mysql
DB_ROOT_PASSWORD=your-mysql-root-password-here

# ⭐️ Sprint 1 — D4: daily reconciliation report (cron 06:00, mailer.js / daily-report.js).
# If SMTP_HOST/SMTP_USER/SMTP_PASS are left unset, the report still generates and logs to
# console but is not emailed (see mailer.js sendMail() fail-soft behavior).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-smtp-username-here
SMTP_PASS=your-smtp-password-or-app-password-here
SMTP_FROM=DMTC Mart <noreply@dmtc.ac.th>

# Recipient of the daily reconciliation report (and future admin alerts). Required for the
# 06:00 cron / POST /api/reports/daily/send to actually send mail.
ADMIN_EMAIL=admin@example.com

# =========================================================================
# ⭐️ PRODUCTION CHECKLIST (ก่อน deploy จริง ต้องแก้ค่าพวกนี้ใน .env จริง — ห้ามใช้ค่า dev)
# -------------------------------------------------------------------------
#  1. NODE_ENV=production        (เปิด rate limit เข้ม 5/30 + trust proxy)
#  2. JWT_SECRET                 สุ่มใหม่ 32+ ตัว (openssl rand -hex 32)
#  3. SETUP_KEY                  สุ่มใหม่ หรือเว้นว่างเพื่อปิด bootstrap endpoint ทั้งหมด
#  4. DB_PASSWORD                รหัสยาวสุ่มจริง (ห้าม root/root)
#  5. FRONTEND_URL               โดเมนจริง https เช่น https://coop.dmtc.ac.th (คุม CORS)
#  6. ฝั่ง frontend ตั้ง VITE_API_URL=https://<โดเมน backend> ใน frontend/.env.production
# =========================================================================
