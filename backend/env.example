# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง — ห้าม commit .env เข้า git

DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_real_db_password
DB_NAME=pos_coop

JWT_SECRET=generate_a_long_random_string_here

# ใช้เฉพาะตอน setup ครั้งแรกเท่านั้น (เรียก /api/init-db, /api/seed-data, /api/create-admin)
# ตั้งค่าเป็น string สุ่มยาวๆ แล้วลบทิ้งจาก .env หลัง setup เสร็จ เพื่อปิด endpoint พวกนี้ถาวร
SETUP_KEY=some_long_random_setup_key
